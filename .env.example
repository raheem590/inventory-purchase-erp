# PostgreSQL connection string (Vercel Postgres or local Postgres)
DATABASE_URL="postgresql://user:password@localhost:5432/inventory_purchase_erp?schema=public"

# Optional direct URL for Prisma migrations (use when DATABASE_URL is pooled)
# DIRECT_URL="postgresql://user:password@localhost:5432/inventory_purchase_erp?schema=public"
PIN_HASH="$2b$10$replace_with_your_bcrypt_hash"

# Random secret at least 32 characters for iron-session
SESSION_SECRET="replace_with_a_long_random_secret_at_least_32_chars"
